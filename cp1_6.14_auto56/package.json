{
  "name": "flower-shop-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "npx tsx watch server/index.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "express": "^4.18.2",
    "lowdb": "^7.0.1",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "moment": "^2.30.1",
    "recharts": "^2.12.0",
    "jspdf": "^2.5.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.20",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.4",
    "typescript": "~5.3.3",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1"
  }
}
