    "cytoscape": "^3.28.1",
    "cytoscape-dagre": "^2.5.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
