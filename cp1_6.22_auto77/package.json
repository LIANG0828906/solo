{
  "name": "team-mindmap-noteboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite --port 3000",
    "server:dev": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "ws": "^8.18.0",
    "uuid": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.12",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "tsx": "^4.16.2",
    "concurrently": "^8.2.2"
  }
}
