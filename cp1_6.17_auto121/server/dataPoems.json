[
  {
    "id": 1,
    "title": "静夜思",
    "author": "李白",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["床前明月光", "疑是地上霜", "举头望明月", "低头思故乡"]
  },
  {
    "id": 2,
    "title": "春晓",
    "author": "孟浩然",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["春眠不觉晓", "处处闻啼鸟", "夜来风雨声", "花落知多少"]
  },
  {
    "id": 3,
    "title": "登鹳雀楼",
    "author": "王之涣",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["白日依山尽", "黄河入海流", "欲穷千里目", "更上一层楼"]
  },
  {
    "id": 4,
    "title": "相思",
    "author": "王维",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["红豆生南国", "春来发几枝", "愿君多采撷", "此物最相思"]
  },
  {
    "id": 5,
    "title": "江雪",
    "author": "柳宗元",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["千山鸟飞绝", "万径人踪灭", "孤舟蓑笠翁", "独钓寒江雪"]
  },
  {
    "id": 6,
    "title": "悯农",
    "author": "李绅",
    "dynasty": "唐",
    "genre": "五绝",
    "lines": 4,
    "content": ["锄禾日当午", "汗滴禾下土", "谁知盘中餐", "粒粒皆辛苦"]
  },
  {
    "id": 7,
    "title": "咏柳",
    "author": "贺知章",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["碧玉妆成一树高", "万条垂下绿丝绦", "不知细叶谁裁出", "二月春风似剪刀"]
  },
  {
    "id": 8,
    "title": "望庐山瀑布",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["日照香炉生紫烟", "遥看瀑布挂前川", "飞流直下三千尺", "疑是银河落九天"]
  },
  {
    "id": 9,
    "title": "枫桥夜泊",
    "author": "张继",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["月落乌啼霜满天", "江枫渔火对愁眠", "姑苏城外寒山寺", "夜半钟声到客船"]
  },
  {
    "id": 10,
    "title": "清明",
    "author": "杜牧",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["清明时节雨纷纷", "路上行人欲断魂", "借问酒家何处有", "牧童遥指杏花村"]
  },
  {
    "id": 11,
    "title": "黄鹤楼送孟浩然之广陵",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["故人西辞黄鹤楼", "烟花三月下扬州", "孤帆远影碧空尽", "唯见长江天际流"]
  },
  {
    "id": 12,
    "title": "早发白帝城",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["朝辞白帝彩云间", "千里江陵一日还", "两岸猿声啼不住", "轻舟已过万重山"]
  },
  {
    "id": 13,
    "title": "望岳",
    "author": "杜甫",
    "dynasty": "唐",
    "genre": "五律",
    "lines": 8,
    "content": ["岱宗夫如何", "齐鲁青未了", "造化钟神秀", "阴阳割昏晓", "荡胸生层云", "决眦入归鸟", "会当凌绝顶", "一览众山小"]
  },
  {
    "id": 14,
    "title": "春望",
    "author": "杜甫",
    "dynasty": "唐",
    "genre": "五律",
    "lines": 8,
    "content": ["国破山河在", "城春草木深", "感时花溅泪", "恨别鸟惊心", "烽火连三月", "家书抵万金", "白头搔更短", "浑欲不胜簪"]
  },
  {
    "id": 15,
    "title": "山居秋暝",
    "author": "王维",
    "dynasty": "唐",
    "genre": "五律",
    "lines": 8,
    "content": ["空山新雨后", "天气晚来秋", "明月松间照", "清泉石上流", "竹喧归浣女", "莲动下渔舟", "随意春芳歇", "王孙自可留"]
  },
  {
    "id": 16,
    "title": "黄鹤楼",
    "author": "崔颢",
    "dynasty": "唐",
    "genre": "七律",
    "lines": 8,
    "content": ["昔人已乘黄鹤去", "此地空余黄鹤楼", "黄鹤一去不复返", "白云千载空悠悠", "晴川历历汉阳树", "芳草萋萋鹦鹉洲", "日暮乡关何处是", "烟波江上使人愁"]
  },
  {
    "id": 17,
    "title": "登高",
    "author": "杜甫",
    "dynasty": "唐",
    "genre": "七律",
    "lines": 8,
    "content": ["风急天高猿啸哀", "渚清沙白鸟飞回", "无边落木萧萧下", "不尽长江滚滚来", "万里悲秋常作客", "百年多病独登台", "艰难苦恨繁霜鬓", "潦倒新停浊酒杯"]
  },
  {
    "id": 18,
    "title": "锦瑟",
    "author": "李商隐",
    "dynasty": "唐",
    "genre": "七律",
    "lines": 8,
    "content": ["锦瑟无端五十弦", "一弦一柱思华年", "庄生晓梦迷蝴蝶", "望帝春心托杜鹃", "沧海月明珠有泪", "蓝田日暖玉生烟", "此情可待成追忆", "只是当时已惘然"]
  },
  {
    "id": 19,
    "title": "水调歌头",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "词",
    "lines": 16,
    "content": ["明月几时有", "把酒问青天", "不知天上宫阙", "今夕是何年", "我欲乘风归去", "又恐琼楼玉宇", "高处不胜寒", "起舞弄清影", "何似在人间", "转朱阁", "低绮户", "照无眠", "不应有恨", "何事长向别时圆", "人有悲欢离合", "月有阴晴圆缺", "此事古难全", "但愿人长久", "千里共婵娟"]
  },
  {
    "id": 20,
    "title": "念奴娇·赤壁怀古",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "词",
    "lines": 18,
    "content": ["大江东去", "浪淘尽", "千古风流人物", "故垒西边", "人道是", "三国周郎赤壁", "乱石穿空", "惊涛拍岸", "卷起千堆雪", "江山如画", "一时多少豪杰", "遥想公瑾当年", "小乔初嫁了", "雄姿英发", "羽扇纶巾", "谈笑间", "樯橹灰飞烟灭", "故国神游", "多情应笑我", "早生华发", "人生如梦", "一尊还酹江月"]
  },
  {
    "id": 21,
    "title": "声声慢",
    "author": "李清照",
    "dynasty": "宋",
    "genre": "词",
    "lines": 20,
    "content": ["寻寻觅觅", "冷冷清清", "凄凄惨惨戚戚", "乍暖还寒时候", "最难将息", "三杯两盏淡酒", "怎敌他", "晚来风急", "雁过也", "正伤心", "却是旧时相识", "满地黄花堆积", "憔悴损", "如今有谁堪摘", "守着窗儿", "独自怎生得黑", "梧桐更兼细雨", "到黄昏", "点点滴滴", "这次第", "怎一个愁字了得"]
  },
  {
    "id": 22,
    "title": "如梦令",
    "author": "李清照",
    "dynasty": "宋",
    "genre": "词",
    "lines": 8,
    "content": ["常记溪亭日暮", "沉醉不知归路", "兴尽晚回舟", "误入藕花深处", "争渡", "争渡", "惊起一滩鸥鹭"]
  },
  {
    "id": 23,
    "title": "卜算子·咏梅",
    "author": "陆游",
    "dynasty": "宋",
    "genre": "词",
    "lines": 10,
    "content": ["驿外断桥边", "寂寞开无主", "已是黄昏独自愁", "更著风和雨", "无意苦争春", "一任群芳妒", "零落成泥碾作尘", "只有香如故"]
  },
  {
    "id": 24,
    "title": "破阵子·为陈同甫赋壮词以寄之",
    "author": "辛弃疾",
    "dynasty": "宋",
    "genre": "词",
    "lines": 12,
    "content": ["醉里挑灯看剑", "梦回吹角连营", "八百里分麾下炙", "五十弦翻塞外声", "沙场秋点兵", "马作的卢飞快", "弓如霹雳弦惊", "了却君王天下事", "赢得生前身后名", "可怜白发生"]
  },
  {
    "id": 25,
    "title": "江城子·密州出猎",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "词",
    "lines": 14,
    "content": ["老夫聊发少年狂", "左牵黄", "右擎苍", "锦帽貂裘", "千骑卷平冈", "为报倾城随太守", "亲射虎", "看孙郎", "酒酣胸胆尚开张", "鬓微霜", "又何妨", "持节云中", "何日遣冯唐", "会挽雕弓如满月", "西北望", "射天狼"]
  },
  {
    "id": 26,
    "title": "渔家傲·秋思",
    "author": "范仲淹",
    "dynasty": "宋",
    "genre": "词",
    "lines": 12,
    "content": ["塞下秋来风景异", "衡阳雁去无留意", "四面边声连角起", "千嶂里", "长烟落日孤城闭", "浊酒一杯家万里", "燕然未勒归无计", "羌管悠悠霜满地", "人不寐", "将军白发征夫泪"]
  },
  {
    "id": 27,
    "title": "雨霖铃",
    "author": "柳永",
    "dynasty": "宋",
    "genre": "词",
    "lines": 18,
    "content": ["寒蝉凄切", "对长亭晚", "骤雨初歇", "都门帐饮无绪", "留恋处", "兰舟催发", "执手相看泪眼", "竟无语凝噎", "念去去", "千里烟波", "暮霭沉沉楚天阔", "多情自古伤离别", "更那堪", "冷落清秋节", "今宵酒醒何处", "杨柳岸", "晓风残月", "此去经年", "应是良辰好景虚设", "便纵有千种风情", "更与何人说"]
  },
  {
    "id": 28,
    "title": "元日",
    "author": "王安石",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["爆竹声中一岁除", "春风送暖入屠苏", "千门万户曈曈日", "总把新桃换旧符"]
  },
  {
    "id": 29,
    "title": "泊船瓜洲",
    "author": "王安石",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["京口瓜洲一水间", "钟山只隔数重山", "春风又绿江南岸", "明月何时照我还"]
  },
  {
    "id": 30,
    "title": "题西林壁",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["横看成岭侧成峰", "远近高低各不同", "不识庐山真面目", "只缘身在此山中"]
  },
  {
    "id": 31,
    "title": "饮湖上初晴后雨",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["水光潋滟晴方好", "山色空蒙雨亦奇", "欲把西湖比西子", "淡妆浓抹总相宜"]
  },
  {
    "id": 32,
    "title": "示儿",
    "author": "陆游",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["死去元知万事空", "但悲不见九州同", "王师北定中原日", "家祭无忘告乃翁"]
  },
  {
    "id": 33,
    "title": "观书有感",
    "author": "朱熹",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["半亩方塘一鉴开", "天光云影共徘徊", "问渠那得清如许", "为有源头活水来"]
  },
  {
    "id": 34,
    "title": "四时田园杂兴",
    "author": "范成大",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["昼出耘田夜绩麻", "村庄儿女各当家", "童孙未解供耕织", "也傍桑阴学种瓜"]
  },
  {
    "id": 35,
    "title": "小池",
    "author": "杨万里",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["泉眼无声惜细流", "树阴照水爱晴柔", "小荷才露尖尖角", "早有蜻蜓立上头"]
  },
  {
    "id": 36,
    "title": "晓出净慈寺送林子方",
    "author": "杨万里",
    "dynasty": "宋",
    "genre": "七绝",
    "lines": 4,
    "content": ["毕竟西湖六月中", "风光不与四时同", "接天莲叶无穷碧", "映日荷花别样红"]
  },
  {
    "id": 37,
    "title": "石灰吟",
    "author": "于谦",
    "dynasty": "明",
    "genre": "七绝",
    "lines": 4,
    "content": ["千锤万凿出深山", "烈火焚烧若等闲", "粉骨碎身浑不怕", "要留清白在人间"]
  },
  {
    "id": 38,
    "title": "竹石",
    "author": "郑燮",
    "dynasty": "清",
    "genre": "七绝",
    "lines": 4,
    "content": ["咬定青山不放松", "立根原在破岩中", "千磨万击还坚劲", "任尔东西南北风"]
  },
  {
    "id": 39,
    "title": "己亥杂诗",
    "author": "龚自珍",
    "dynasty": "清",
    "genre": "七绝",
    "lines": 4,
    "content": ["九州生气恃风雷", "万马齐喑究可哀", "我劝天公重抖擞", "不拘一格降人才"]
  },
  {
    "id": 40,
    "title": "村居",
    "author": "高鼎",
    "dynasty": "清",
    "genre": "七绝",
    "lines": 4,
    "content": ["草长莺飞二月天", "拂堤杨柳醉春烟", "儿童散学归来早", "忙趁东风放纸鸢"]
  },
  {
    "id": 41,
    "title": "所见",
    "author": "袁枚",
    "dynasty": "清",
    "genre": "五绝",
    "lines": 4,
    "content": ["牧童骑黄牛", "歌声振林樾", "意欲捕鸣蝉", "忽然闭口立"]
  },
  {
    "id": 42,
    "title": "游子吟",
    "author": "孟郊",
    "dynasty": "唐",
    "genre": "五古",
    "lines": 6,
    "content": ["慈母手中线", "游子身上衣", "临行密密缝", "意恐迟迟归", "谁言寸草心", "报得三春晖"]
  },
  {
    "id": 43,
    "title": "望天门山",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["天门中断楚江开", "碧水东流至此回", "两岸青山相对出", "孤帆一片日边来"]
  },
  {
    "id": 44,
    "title": "绝句",
    "author": "杜甫",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["两个黄鹂鸣翠柳", "一行白鹭上青天", "窗含西岭千秋雪", "门泊东吴万里船"]
  },
  {
    "id": 45,
    "title": "乌衣巷",
    "author": "刘禹锡",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["朱雀桥边野草花", "乌衣巷口夕阳斜", "旧时王谢堂前燕", "飞入寻常百姓家"]
  },
  {
    "id": 46,
    "title": "浪淘沙",
    "author": "刘禹锡",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["九曲黄河万里沙", "浪淘风簸自天涯", "如今直上银河去", "同到牵牛织女家"]
  },
  {
    "id": 47,
    "title": "赋得古原草送别",
    "author": "白居易",
    "dynasty": "唐",
    "genre": "五律",
    "lines": 8,
    "content": ["离离原上草", "一岁一枯荣", "野火烧不尽", "春风吹又生", "远芳侵古道", "晴翠接荒城", "又送王孙去", "萋萋满别情"]
  },
  {
    "id": 48,
    "title": "暮江吟",
    "author": "白居易",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["一道残阳铺水中", "半江瑟瑟半江红", "可怜九月初三夜", "露似真珠月似弓"]
  },
  {
    "id": 49,
    "title": "嫦娥",
    "author": "李商隐",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["云母屏风烛影深", "长河渐落晓星沉", "嫦娥应悔偷灵药", "碧海青天夜夜心"]
  },
  {
    "id": 50,
    "title": "江南春",
    "author": "杜牧",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
    "content": ["千里莺啼绿映红", "水村山郭酒旗风", "南朝四百八十寺", "多少楼台烟雨中"]
  },
  {
    "id": 51,
    "title": "山行",
    "author": "杜牧",
    "dynasty": "唐",
    "genre": "七绝",
    "lines": 4,
