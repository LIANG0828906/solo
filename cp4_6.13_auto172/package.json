{
  "name": "traffic-heatmap-3d",
  "version": "1.0.0",
  "description": "城市交通流量3D热力图模拟系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --port 3000",
    "dev:backend": "tsx src/dataServer.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/three": "^0.160.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
}
