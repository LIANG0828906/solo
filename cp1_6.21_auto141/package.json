    "react-dom": "^18.3.1",
    "three": "^0.160.0",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "concurrently": "^9.2.0"
  }
}
