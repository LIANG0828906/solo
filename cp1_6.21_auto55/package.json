{
  "name": "molecule-viewer",
  "version": "1.0.0",
  "description": "Interactive 3D molecular structure viewer and reaction path simulator",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
