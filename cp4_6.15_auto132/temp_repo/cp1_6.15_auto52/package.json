{
  "name": "underwater-archaeology-explorer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build-server": "tsc -p server/tsconfig.json",
    "dev": "npm run build-server && concurrently \"npm:watch-server\" \"npm:serve\" \"npm:client\"",
    "watch-server": "tsc -p server/tsconfig.json --watch",
    "serve": "node server/dist/index.js",
    "server": "npm run build-server && npm run serve",
    "client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "three": "^0.160.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/three": "^0.160.0",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
