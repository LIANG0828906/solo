{
  "name": "livevote",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "perf:test": "node perf/performance-test.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.19",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "@types/uuid": "^9.0.5",
    "@types/ws": "^8.5.7",
    "@vitejs/plugin-react": "^4.1.0",
    "concurrently": "^8.2.2",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2",
    "vite": "^4.5.0"
  }
}
