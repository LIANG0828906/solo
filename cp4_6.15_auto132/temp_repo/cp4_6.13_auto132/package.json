{
  "name": "music-collab-whiteboard",
  "version": "1.0.0",
  "description": "Music creation collaborative whiteboard",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node server/src/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "install:all": "npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.9",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
