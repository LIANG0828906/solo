{
  "name": "word-context-learning",
  "version": "1.0.0",
  "description": "沉浸式上下文单词学习Web应用",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "tsx watch server/src/index.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "cors": "^2.8.5",
    "lucide-react": "^0.511.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/cors": "^2.8.19",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.3"
  }
}
