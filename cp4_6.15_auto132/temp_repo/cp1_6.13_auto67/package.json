    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "react-beautiful-dnd": "^13.1.1",
    "qrcode.react": "^3.1.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/react-beautiful-dnd": "^13.1.6",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.16",
    "@types/uuid": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "tsx": "^4.1.0",
    "concurrently": "^8.2.2"
  }
