{
  "name": "interactive-word-cloud",
  "version": "1.0.0",
  "description": "Interactive word cloud application with dynamic visualization",
  "main": "backend/dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node --project backend/tsconfig.json backend/src/server.ts",
    "build": "tsc -p backend && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "d3": "^7.8.5",
    "d3-cloud": "^1.2.7",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "nodejieba": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/d3": "^7.4.3",
    "@types/d3-cloud": "^1.2.8",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
