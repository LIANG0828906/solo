{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-server",
    "rootDir": "./",
    "types": ["node", "express"]
  },
  "include": ["server/**/*.ts", "src/types.ts"],
  "exclude": ["node_modules", "src/**/*.tsx", "src/**/*.ts"]
}
