{
  "name": "craft-studio-order-system",
  "version": "1.0.0",
  "description": "手工艺工作室客户定制订单管理系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node --esm server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7",
    "react-router-dom": "^6.20.0",
    "uuid": "^9.0.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "lowdb": "1.0.0",
    "@fortawesome/fontawesome-free": "^6.5.1"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.4",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
