{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["es2020", "dom"],
    "types": ["three"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
