                            "weight": {
                              "type": "string",
                              "example": "50g"
                            },
                            "battery": {
                              "type": "string",
                              "example": "30小时"
                            }
                          }
                        },
                        "isActive": {
                          "type": "boolean",
                          "example": true
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "产品不存在",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "message": {
                      "type": "string",
                      "example": "产品不存在"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["产品管理"],
        "summary": "更新产品",
        "description": "更新产品信息",
        "operationId": "updateProduct",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "description": "产品ID",
            "required": true,
            "schema": {
              "type": "string",
              "example": "prod_001"
            }
