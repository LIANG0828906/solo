            "schema": {
              "type": "string",
              "example": "prod_001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回产品详情",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "prod_001"
                        },
                        "name": {
                          "type": "string",
                          "example": "无线蓝牙耳机"
                        },
                        "description": {
                          "type": "string",
                          "example": "高品质无线蓝牙耳机"
                        },
                        "price": {
                          "type": "number",
                          "example": 299.99
                        },
                        "originalPrice": {
                          "type": "number",
                          "example": 399.99
                        },
                        "stock": {
                          "type": "integer",
                          "example": 156
                        },
                        "sales": {
                          "type": "integer",
                          "example": 1234
                        },
                        "category": {
                          "type": "string",
                          "example": "electronics"
                        },
                        "images": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "format": "uri"
