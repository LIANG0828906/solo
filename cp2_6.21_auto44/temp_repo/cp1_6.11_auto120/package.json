{
  "name": "flavor-topology",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "tsx watch src/server/server.ts",
    "dev": "concurrently -k \"npm run server:dev\" \"npm run client:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
