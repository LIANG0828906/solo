    "@vitejs/plugin-react": "^4.4.1",
    "ws": "^8.18.0",
    "express": "^4.21.2",
    "uuid": "^9.0.1",
    "canvas-confetti": "^1.9.3",
    "lucide-react": "^0.511.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/ws": "^8.5.13",
