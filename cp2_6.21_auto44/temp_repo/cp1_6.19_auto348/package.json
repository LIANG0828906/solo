{
  "name": "knowledge-card-generator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon --watch src/server src/server/index.js",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\""
  },
  "dependencies": {
