{
  "name": "survey-app",
  "version": "1.0.0",
  "description": "Online survey creation and data collection application",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "start": "ts-node server/index.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^11.3.0",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "recharts": "^2.10.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
