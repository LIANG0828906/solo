{
  "name": "digital-card-exchange",
  "version": "1.0.0",
  "description": "在线数字名片交换与名片盒管理应用",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon --exec \"ts-node --project tsconfig.server.json\" server/src/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.14.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/ws": "^8.5.5",
    "@types/uuid": "^9.0.2",
    "@types/node": "^20.4.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.0",
    "@vitejs/plugin-react": "^4.0.3",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0"
  }
}
