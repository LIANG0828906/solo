{
  "name": "fern-evolution-simulator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch server --exec \"node --loader ts-node/esm server/index.ts",
    "build": "tsc --noEmit && vite build",
    "build:client": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.160.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "concurrently": "^8.2.2"
  }
}
