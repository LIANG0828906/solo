{
  "name": "retro-card-exchange",
  "version": "1.0.0",
  "description": "电子复古名片交换站",
  "main": "server.ts",
  "scripts": {
    "dev": "concurrently \"nodemon --watch server.ts --ext ts server.ts\" \"npx http-server public -p 8080 -c-1\"",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1"
  }
}
