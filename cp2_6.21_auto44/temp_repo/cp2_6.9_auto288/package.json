{
  "name": "bamboo-weaving-workshop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "check": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "framer-motion": "^11.2.10",
    "three": "^0.165.0",
    "@react-three/fiber": "^8.16.8",
    "@react-three/drei": "^9.108.3",
    "file-saver": "^2.0.5",
    "zustand": "^5.0.3",
    "react-router-dom": "^7.3.0",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/three": "^0.165.0",
    "@types/file-saver": "^2.0.7",
    "tsx": "^4.15.7",
    "concurrently": "^8.2.2"
  }
}
