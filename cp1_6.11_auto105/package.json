{
  "name": "danmaku-canvas-collab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx src/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/uuid": "^9.0.4",
    "@types/ws": "^8.5.6",
    "concurrently": "^8.2.1",
    "tsx": "^3.13.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9"
  }
}
