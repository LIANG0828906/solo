  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "tsx": "^4.16.2",
    "concurrently": "^8.2.2"
  }
}
