{
  "name": "virtual-whiteboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "axios": "^1.7.4",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "lowdb": "^7.0.1",
    "uuid": "^10.0.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
