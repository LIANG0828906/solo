    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "gif-encoder-2": "^1.0.5",
    "get-pixels": "^3.3.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
