{
  "name": "leathercraft-order-management",
  "version": "1.0.0",
  "description": "皮具定制订单与皮革原料库存管理应用",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
