    "@types/react-dom": "^18.2.19",
    "@types/ws": "^8.5.10",
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "vite": "^5.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1"
