{
  "name": "meeting-manager",
  "version": "1.0.0",
  "description": "Lightweight team meeting and action item management app",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm install && npx ts-node src/index.ts",
    "dev:client": "npm install && npx vite",
    "build": "npx tsc && npx vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "typescript": "^5.3.0",
    "concurrently": "^8.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.1"
  }
}
