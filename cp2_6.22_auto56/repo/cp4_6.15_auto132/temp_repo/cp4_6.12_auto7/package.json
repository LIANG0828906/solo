{
  "name": "woodwork-workshop-manager",
  "version": "1.0.0",
  "description": "木作工坊管理系统 - 客户定制项目、木料库存和工具维护管理",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node src/backend/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.7",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "@types/react": "^18.2.40",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
