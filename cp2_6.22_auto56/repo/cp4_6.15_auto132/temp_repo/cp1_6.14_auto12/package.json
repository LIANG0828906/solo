    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "lowdb": "^7.0.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/leaflet": "^1.9.12",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.1",
