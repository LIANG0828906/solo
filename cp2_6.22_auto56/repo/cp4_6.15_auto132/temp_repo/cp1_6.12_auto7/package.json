{
  "name": "knowledge-graph-app",
  "version": "1.0.0",
  "description": "Personal Knowledge Graph Management Application",
  "main": "dist/backend/server.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "ts-node src/backend/server.ts",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "d3": "^7.8.5",
    "express": "^4.18.2",
    "nedb": "^1.8.0",
    "uuid": "^9.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/d3": "^7.4.0",
    "@types/express": "^4.17.17",
    "@types/nedb": "^1.8.13",
    "@types/uuid": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/node": "^20.4.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0"
