{
  "name": "collaborative-writing-platform",
  "version": "1.0.0",
  "description": "A real-time collaborative writing platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.0",
    "diff": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/express": "^4.17.17",
    "@types/uuid": "^9.0.2",
    "@types/diff": "^5.0.3",
    "typescript": "^5.1.6",
    "vite": "^4.4.5",
    "@vitejs/plugin-react": "^4.0.3",
    "tsx": "^3.12.7",
    "concurrently": "^8.2.0"
  }
}
