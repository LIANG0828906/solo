{
  "name": "office-preference",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "node --watch server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\""
  },
