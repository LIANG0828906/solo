    "framer-motion": "^11.3.0",
    "zustand": "^4.5.4",
    "recharts": "^2.12.7",
    "express": "^4.19.2",
    "uuid": "^9.0.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/uuid": "^9.0.8",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "~5.4.5",
    "vite": "^5.3.3",
    "nodemon": "^3.1.4",
    "tsx": "^4.16.2",
    "concurrently": "^8.2.2"
