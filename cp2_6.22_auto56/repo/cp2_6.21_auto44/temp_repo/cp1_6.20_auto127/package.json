{
  "name": "portfolio-layout-editor",
  "version": "1.0.0",
  "description": "在线作品集布局模板编辑器与版本对比系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/index.ts",
    "client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "html-to-image": "^1.11.11"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/uuid": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/body-parser": "^1.19.2",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.1.0",
    "vite": "^4.3.0",
    "tsx": "^3.12.7",
    "concurrently": "^8.2.0"
  }
}
