{
  "name": "collaborative-text-editor",
  "version": "1.0.0",
  "description": "基于文本分块的协同编辑与差异高亮Web应用",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc",
    "preview": "vite preview",
    "server": "node server.js",
    "server:dev": "ts-node --esm src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "diff": "^5.2.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/diff": "^5.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
