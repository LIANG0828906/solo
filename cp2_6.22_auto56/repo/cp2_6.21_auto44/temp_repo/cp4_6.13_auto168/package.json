{
  "name": "code-theme-compare",
  "version": "1.0.0",
  "description": "Code snippet style comparison displayer",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "ts-node server/index.ts",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "express": "^4.18.2",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "@vitejs/plugin-vue": "^5.0.0",
    "@types/node": "^20.10.5",
    "vue-tsc": "^1.8.25",
    "ts-node": "^10.9.2",
    "@types/express": "^4.17.21",
    "concurrently": "^8.2.2"
  }
}
