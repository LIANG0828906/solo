{
  "name": "shenglang-final",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:back\"",
    "dev:front": "vite",
    "dev:back": "ts-node --esm server/index.ts",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "socket.io-client": "^4.7.0",
    "zustand": "^4.5.0",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "@types/cors": "^2.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.0"
  }
