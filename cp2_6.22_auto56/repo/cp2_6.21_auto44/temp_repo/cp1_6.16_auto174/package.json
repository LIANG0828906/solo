{
  "name": "music-score-editor",
  "version": "1.0.0",
  "description": "Music Score Editor - visual multi-track score editing with real-time audio synthesis",
  "main": "server/api.ts",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "ts-node --project tsconfig.server.json server/api.ts",
    "client": "vite",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.12.0",
    "@ant-design/icons": "^5.2.6",
    "zustand": "^4.4.7",
    "vexflow": "^4.2.3",
    "tone": "^14.7.77",
    "uuid": "^9.0.1",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
