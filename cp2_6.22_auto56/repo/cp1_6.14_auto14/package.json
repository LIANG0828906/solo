{
  "name": "moodboard-tool",
  "version": "1.0.0",
  "description": "灵感素材管理与配色方案生成工具",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "lowdb": "^6.1.1",
    "uuid": "^9.0.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0"
  }
}
