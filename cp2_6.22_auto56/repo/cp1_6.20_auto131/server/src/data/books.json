    "reviews": [
      { "id": "1-1", "username": "书虫老张", "rating": 5, "content": "马尔克斯的魔幻现实主义令人叹服，布恩迪亚家族的百年兴衰如同一场大梦，读完后久久不能平静。", "timestamp": "2026-06-01T09:15:00Z" },
      { "id": "1-2", "username": "夜读者", "rating": 4, "content": "这部作品的结构非常精妙，循环往复的时间线让人沉浸其中，但人物名字重复确实容易混淆。", "timestamp": "2026-06-01T14:30:00Z" },
      { "id": "1-3", "username": "理性书客", "rating": 3, "content": "经典归经典，但阅读门槛确实很高，大量人名和复杂的家族关系让人头疼，需要耐心才能读完。", "timestamp": "2026-06-02T10:20:00Z" },
      { "id": "1-4", "username": "文艺少女", "rating": 5, "content": "每一次重读都能发现新的细节和隐喻，这才是真正的不朽之作，值得反复品味。", "timestamp": "2026-06-03T08:45:00Z" },
      { "id": "1-5", "username": "沉默读者", "rating": 3, "content": "孤独的主题贯穿始终，但叙事节奏有时过于缓慢，部分段落显得冗长乏味。", "timestamp": "2026-06-04T16:00:00Z" },
      { "id": "1-6", "username": "拉美迷", "rating": 4, "content": "拉丁美洲的历史缩影，魔幻与现实的交织天衣无缝，文学的魅力在这里展现得淋漓尽致。", "timestamp": "2026-06-05T11:30:00Z" },
      { "id": "1-7", "username": "追光者", "rating": 5, "content": "开篇第一句就足以载入史册，整个故事如同一场华丽的梦境，让人沉醉其中无法自拔。", "timestamp": "2026-06-06T20:15:00Z" },
      { "id": "1-8", "username": "小白读书", "rating": 2, "content": "名字重复太多，读到后面完全分不清谁是谁，体验很差，不推荐给没有耐心的读者。", "timestamp": "2026-06-07T09:00:00Z" },
      { "id": "1-9", "username": "文学青年", "rating": 4, "content": "百年家族的孤独宿命令人感慨万千，马尔克斯的笔触既有宏大叙事又不失细腻情感。", "timestamp": "2026-06-08T13:20:00Z" },
      { "id": "1-10", "username": "深海鱼", "rating": 3, "content": "整体氛围压抑，人物命运令人窒息，虽然文学价值极高但阅读体验并不轻松。", "timestamp": "2026-06-09T15:40:00Z" },
      { "id": "1-11", "username": "新视野", "rating": 5, "content": "这部小说彻底改变了我对文学的认知，魔幻现实主义原来可以写得如此扣人心弦。", "timestamp": "2026-06-10T10:10:00Z" },
      { "id": "1-12", "username": "墨香书屋", "rating": 5, "content": "世界文学的巅峰之作，每一个角色都承载着孤独的命运，读后令人反思人生的本质。", "timestamp": "2026-06-11T17:50:00Z" },
      { "id": "1-13", "username": "挑刺王", "rating": 2, "content": "过誉了，翻译质量一般，很多地方读起来生硬，原作的韵味大打折扣。", "timestamp": "2026-06-12T08:30:00Z" },
      { "id": "1-14", "username": "书山有路", "rating": 4, "content": "第三代到第五代的故事最为精彩，家族的兴衰轮回令人拍案叫绝。", "timestamp": "2026-06-13T12:00:00Z" },
      { "id": "1-15", "username": "慢读派", "rating": 3, "content": "书是好书，但确实不适合所有读者，需要一定的文学素养和耐心才能领略其妙处。", "timestamp": "2026-06-14T19:30:00Z" },
      { "id": "1-16", "username": "梦想家", "rating": 5, "content": "马尔克斯用魔幻的笔触写出了最真实的孤独，这种矛盾的统一正是天才的标志。", "timestamp": "2026-06-15T07:45:00Z" },
      { "id": "1-17", "username": "云端漫步", "rating": 5, "content": "读完最后一页，仿佛经历了一百年的沧桑，这种阅读体验无与伦比。", "timestamp": "2026-06-16T14:15:00Z" },
      { "id": "1-18", "username": "凡人语", "rating": 2, "content": "太难读了，坚持了两个月才勉强看完，不能否认其文学地位但实在不是我的菜。", "timestamp": "2026-06-17T11:00:00Z" },
      { "id": "1-19", "username": "星河阅读", "rating": 4, "content": "每个角色都像一面镜子，映照出人性中不同的孤独面孔，深刻而震撼。", "timestamp": "2026-06-18T16:30:00Z" },
      { "id": "1-20", "username": "清风明月", "rating": 3, "content": "魔幻现实主义的手法很独特，但有些情节过于荒诞，影响了故事的真实感。", "timestamp": "2026-06-20T09:20:00Z" }
    ]
  },
