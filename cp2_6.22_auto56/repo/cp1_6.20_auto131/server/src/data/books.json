    "reviews": [
      { "id": "2-1", "username": "泪点低", "rating": 5, "content": "余华用最朴素的语言写出了最深刻的苦难，福贵的一生让人泪流满面却又不忍释卷。", "timestamp": "2026-06-01T10:00:00Z" },
      { "id": "2-2", "username": "生命旅者", "rating": 5, "content": "读完久久不能平静，活着本身就是最大的勇气，这本书让我重新理解了生命的意义。", "timestamp": "2026-06-01T15:30:00Z" },
      { "id": "2-3", "username": "轻松派", "rating": 3, "content": "很沉重的故事，接连不断的死亡让人窒息，虽然写得好但读起来太痛苦了。", "timestamp": "2026-06-02T09:45:00Z" },
      { "id": "2-4", "username": "素言", "rating": 4, "content": "简单的文字承载着巨大的力量，余华的克制反而让悲伤更加刻骨铭心。", "timestamp": "2026-06-03T12:20:00Z" },
      { "id": "2-5", "username": "书海拾贝", "rating": 5, "content": "每次读都会哭，福贵面对命运的态度让人既心疼又敬佩，这才是中国文学的力量。", "timestamp": "2026-06-04T08:10:00Z" },
      { "id": "2-6", "username": "阳光心态", "rating": 2, "content": "太压抑了，读完心情低落了好几天，虽然文学价值很高但不建议心情不好的时候读。", "timestamp": "2026-06-05T17:30:00Z" },
      { "id": "2-7", "username": "深思者", "rating": 4, "content": "活着的意义或许就是活着本身，余华用福贵的一生告诉我们生命不需要任何理由。", "timestamp": "2026-06-06T11:15:00Z" },
      { "id": "2-8", "username": "质疑者", "rating": 3, "content": "故事虽然感人但情节过于残酷，感觉作者在刻意堆砌苦难，有些不真实。", "timestamp": "2026-06-07T14:00:00Z" },
      { "id": "2-9", "username": "国风书友", "rating": 5, "content": "中国当代文学的丰碑，平凡人的不平凡命运，每一个字都重若千钧。", "timestamp": "2026-06-08T10:30:00Z" },
      { "id": "2-10", "username": "笔锋如刀", "rating": 4, "content": "余华的叙事风格干净利落，没有丝毫矫情，反而更加直击人心，令人叹服。", "timestamp": "2026-06-09T16:45:00Z" },
      { "id": "2-11", "username": "理性之声", "rating": 2, "content": "一个人的运气不可能差到这种程度吧，苦难太多了反而显得刻意和虚假。", "timestamp": "2026-06-10T09:00:00Z" },
      { "id": "2-12", "username": "时代记录", "rating": 5, "content": "时代洪流中普通人的命运如此脆弱，这本书是对那个年代最好的记录和反思。", "timestamp": "2026-06-11T13:20:00Z" },
      { "id": "2-13", "username": "牧歌", "rating": 4, "content": "福贵和那头老牛的画面永远印在我脑海里，活着的坚韧远比死亡更需要勇气。", "timestamp": "2026-06-12T18:30:00Z" },
      { "id": "2-14", "username": "挑剔鬼", "rating": 3, "content": "故事很真实也很残酷，但结尾的平淡让我觉得有些仓促，好像少了点什么。", "timestamp": "2026-06-13T07:50:00Z" },
      { "id": "2-15", "username": "心语者", "rating": 5, "content": "没有任何说教却让人深省，这就是大师的功力，活着本身就是最好的回答。", "timestamp": "2026-06-14T11:00:00Z" },
      { "id": "2-16", "username": "节奏控", "rating": 3, "content": "中间部分节奏有点拖沓，有些段落的苦难描写可以更精炼一些，但整体仍然出色。", "timestamp": "2026-06-15T15:40:00Z" },
      { "id": "2-17", "username": "浮生若梦", "rating": 5, "content": "从富家少爷到孤苦老人，福贵的每一步都踩在读者的心上，伟大的作品。", "timestamp": "2026-06-16T10:20:00Z" },
      { "id": "2-18", "username": "逆耳忠言", "rating": 2, "content": "感觉就是卖惨，一个接一个的死，缺乏更深层的思考，不如余华的其他作品。", "timestamp": "2026-06-17T14:50:00Z" },
      { "id": "2-19", "username": "隔代共鸣", "rating": 4, "content": "每一代人都能从福贵身上看到自己祖辈的影子，这就是经典的永恒魅力。", "timestamp": "2026-06-18T08:30:00Z" },
      { "id": "2-20", "username": "感恩生活", "rating": 5, "content": "读完这本书后对生活充满了感恩，活着就是最大的幸运，余华真是天才。", "timestamp": "2026-06-20T12:10:00Z" }
    ]
  },
