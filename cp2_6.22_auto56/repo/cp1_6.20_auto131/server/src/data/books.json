      { "id": "5-1", "username": "大局观", "rating": 5, "content": "赫拉利用宏大的视角重新审视人类历史，认知革命的提法令人耳目一新，强烈推荐。", "timestamp": "2026-06-01T10:30:00Z" },
      { "id": "5-2", "username": "跨界读者", "rating": 4, "content": "跨学科的写法很有启发性，从生物学到历史学到经济学，视野非常开阔。", "timestamp": "2026-06-01T15:45:00Z" },
      { "id": "5-3", "username": "学术派", "rating": 3, "content": "很多观点缺乏严谨的学术论证，作为通俗读物可以但不要当学术著作来读。", "timestamp": "2026-06-02T09:20:00Z" },
      { "id": "5-4", "username": "思维革命", "rating": 5, "content": "这本书彻底改变了我看待世界的方式，虚构故事维持社会秩序的观点令人震撼。", "timestamp": "2026-06-03T13:00:00Z" },
      { "id": "5-5", "username": "折中派", "rating": 4, "content": "虽然有些偏颇和简化，但作为大众读物非常成功，让人对人类未来充满思考。", "timestamp": "2026-06-04T16:30:00Z" },
      { "id": "5-6", "username": "严谨怪", "rating": 2, "content": "过于简化复杂的历史进程，很多结论过于武断，学术性不足，不推荐作为严肃读物。", "timestamp": "2026-06-05T08:50:00Z" },
      { "id": "5-7", "username": "历史爱好者", "rating": 5, "content": "从认知革命到科学革命，赫拉利用清晰的脉络把七万年的历史串联起来，精彩绝伦。", "timestamp": "2026-06-06T11:15:00Z" },
      { "id": "5-8", "username": "细节控", "rating": 3, "content": "思路很开阔但论证不够严谨，部分章节有堆砌资料的感觉，读起来有些冗长。", "timestamp": "2026-06-07T14:40:00Z" },
      { "id": "5-9", "username": "反向思考", "rating": 5, "content": "小麦驯化了人类而非人类驯化了小麦，这种反向思考太妙了，令人拍案叫绝。", "timestamp": "2026-06-08T10:00:00Z" },
      { "id": "5-10", "username": "科普迷", "rating": 4, "content": "作为历史科普读物非常出色，虽然专业性不足但激发了无数人的思考兴趣。", "timestamp": "2026-06-09T17:20:00Z" },
      { "id": "5-11", "username": "东方视角", "rating": 3, "content": "作者的西方视角太明显了，对非西方文明的描述不够全面，有些观点过于偏颇。", "timestamp": "2026-06-10T09:30:00Z" },
      { "id": "5-12", "username": "想象之力", "rating": 5, "content": "最喜欢讨论想象共同体的部分，金钱、宗教、国家都是虚构的故事，太深刻了。", "timestamp": "2026-06-11T12:10:00Z" },
      { "id": "5-13", "username": "质疑精神", "rating": 5, "content": "赫拉利的洞察力令人叹服，农业革命是史上最大的骗局这个论点虽争议但引人深思。", "timestamp": "2026-06-12T15:50:00Z" },
      { "id": "5-14", "username": "逻辑猎手", "rating": 2, "content": "观点新颖但经不起推敲，很多地方逻辑不严密，读起来像通俗杂志文章而非学术著作。", "timestamp": "2026-06-13T08:20:00Z" },
      { "id": "5-15", "username": "科学之光", "rating": 4, "content": "科学革命部分的论述非常精彩，承认无知的观念如何改变世界，这个视角太独特了。", "timestamp": "2026-06-14T13:30:00Z" },
      { "id": "5-16", "username": "深潜者", "rating": 3, "content": "适合作为入门科普，但深度不够，对任何话题都只是浅尝辄止，缺乏深入分析。", "timestamp": "2026-06-15T16:00:00Z" },
      { "id": "5-17", "username": "终极追问", "rating": 5, "content": "从动物到上帝，人类的历史就是一部虚构的历史，这本书让人重新思考一切。", "timestamp": "2026-06-16T10:45:00Z" },
      { "id": "5-18", "username": "开放心态", "rating": 4, "content": "虽然有些地方不够严谨，但打开了跨学科思考的大门，这种写作勇气值得赞叹。", "timestamp": "2026-06-17T14:20:00Z" },
      { "id": "5-19", "username": "批评家", "rating": 3, "content": "整体框架不错但细节经不起推敲，有些类比过于牵强，降低了论述的说服力。", "timestamp": "2026-06-18T09:00:00Z" },
      { "id": "5-20", "username": "通才读者", "rating": 5, "content": "把七万年的历史写成一本引人入胜的书，赫拉利的叙事能力堪称卓越。", "timestamp": "2026-06-20T11:30:00Z" }
