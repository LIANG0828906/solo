    "reviews": [
      { "id": "7-1", "username": "千千万万", "rating": 5, "content": "为你千千万万遍，这句话足以让每个人泪流满面，哈桑的忠诚令人心碎。", "timestamp": "2026-06-01T08:30:00Z" },
      { "id": "7-2", "username": "阿富汗水", "rating": 5, "content": "关于友谊、背叛与救赎的故事，胡赛尼用深情笔触写出了阿富汗的苦难与希望。", "timestamp": "2026-06-01T13:50:00Z" },
      { "id": "7-3", "username": "公正评判", "rating": 3, "content": "阿米尔的懦弱让人愤怒，虽然最终走上了救赎之路但伤害已经无法弥补。", "timestamp": "2026-06-02T10:20:00Z" },
      { "id": "7-4", "username": "风筝手", "rating": 5, "content": "风筝大赛的描写太震撼了，那一刻的背叛和内疚将伴随读者很久很久。", "timestamp": "2026-06-03T15:40:00Z" },
      { "id": "7-5", "username": "感动有余", "rating": 4, "content": "故事感人至深，阿富汗的变迁让人唏嘘，但部分情节略显刻意和煽情。", "timestamp": "2026-06-04T09:00:00Z" },
      { "id": "7-6", "username": "人性之光", "rating": 5, "content": "每个人心中都有一个哈桑，也有一个阿米尔，这本书让我们直面内心的懦弱。", "timestamp": "2026-06-05T16:30:00Z" },
      { "id": "7-7", "username": "冷眼读书", "rating": 2, "content": "阿米尔的自私让人无法共情，虽然作者想写救赎但我觉得力度不够，矫情了。", "timestamp": "2026-06-06T11:10:00Z" },
      { "id": "7-8", "username": "中亚迷", "rating": 4, "content": "胡赛尼对阿富汗文化的描写非常动人，战前与战后的对比令人心痛不已。", "timestamp": "2026-06-07T14:50:00Z" },
      { "id": "7-9", "username": "为你千遍", "rating": 5, "content": "救赎的主题贯穿始终，为你千千万万遍不仅是一句台词更是一种信念。", "timestamp": "2026-06-08T08:20:00Z" },
      { "id": "7-10", "username": "真实至上", "rating": 3, "content": "前半部分很精彩但后半段阿米尔回阿富汗的情节太戏剧化了，不够真实。", "timestamp": "2026-06-09T17:00:00Z" },
      { "id": "7-11", "username": "对比读者", "rating": 5, "content": "哈桑的纯真与阿米尔的复杂形成强烈对比，人性在战争面前显得格外脆弱。", "timestamp": "2026-06-10T10:40:00Z" },
      { "id": "7-12", "username": "勇敢者", "rating": 5, "content": "这本书教会我勇敢面对自己的过错，逃避只会让内疚变成终生的枷锁。", "timestamp": "2026-06-11T13:20:00Z" },
      { "id": "7-13", "username": "逻辑骑士", "rating": 3, "content": "虽然故事感人但有些情节过于戏剧化，阿米尔回到喀布尔的经历太不真实了。", "timestamp": "2026-06-12T09:30:00Z" },
      { "id": "7-14", "username": "风与筝", "rating": 5, "content": "风筝象征着希望和自由，在战火纷飞的阿富汗这个意象格外令人动容。", "timestamp": "2026-06-13T16:10:00Z" },
      { "id": "7-15", "username": "悲欣交集", "rating": 4, "content": "阿富汗的美丽与残酷交织在一起，胡赛尼的文字有令人治愈又令人心碎的力量。", "timestamp": "2026-06-14T11:50:00Z" },
      { "id": "7-16", "username": "克制派", "rating": 2, "content": "过于煽情了，很多情节感觉是刻意安排来催泪的，缺乏文学上的深度和克制。", "timestamp": "2026-06-15T08:00:00Z" },
      { "id": "7-17", "username": "救赎之路", "rating": 5, "content": "阿米尔的成长就是从逃避到面对的过程，每个人都需要这样的救赎之旅。", "timestamp": "2026-06-16T14:30:00Z" },
      { "id": "7-18", "username": "技法评", "rating": 4, "content": "作为处女作已经非常出色了，虽然技法上有些生硬但情感的力量足以弥补。", "timestamp": "2026-06-17T10:10:00Z" },
      { "id": "7-19", "username": "纯真之光", "rating": 5, "content": "哈桑那句为你千千万万遍每次想起都红了眼眶，纯粹的善良是这个世界的光。", "timestamp": "2026-06-18T15:40:00Z" },
