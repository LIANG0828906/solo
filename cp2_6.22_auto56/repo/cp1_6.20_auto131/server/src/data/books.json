    "reviews": [
      { "id": "4-1", "username": "玫瑰心", "rating": 5, "content": "每次重读都会被深深感动，小王子和玫瑰的故事让人懂得了什么是真正的爱与责任。", "timestamp": "2026-06-01T09:30:00Z" },
      { "id": "4-2", "username": "童话大朋友", "rating": 5, "content": "看似童话实则写给大人，每个角色都映射着成人世界的荒诞，令人深思。", "timestamp": "2026-06-01T14:00:00Z" },
      { "id": "4-3", "username": "高标准", "rating": 3, "content": "故事很短很温馨，但说实话没有传说中那么惊艳，可能是期望太高了。", "timestamp": "2026-06-02T11:20:00Z" },
      { "id": "4-4", "username": "真心话", "rating": 5, "content": "驯养的概念太美了，正是你为你的玫瑰花费的时间才使她变得如此珍贵。", "timestamp": "2026-06-03T08:45:00Z" },
      { "id": "4-5", "username": "插画控", "rating": 4, "content": "插画和文字配合得天衣无缝，简单的文字里藏着最深刻的哲理，经典就是经典。", "timestamp": "2026-06-04T16:30:00Z" },
      { "id": "4-6", "username": "理性眼", "rating": 3, "content": "适合小孩子读的童话，大人的感动可能更多来自对童年的怀念而非故事本身。", "timestamp": "2026-06-05T10:15:00Z" },
      { "id": "4-7", "username": "心灵捕手", "rating": 5, "content": "用心才能看清本质，真正重要的东西眼睛是看不见的，这句话改变了我的一生。", "timestamp": "2026-06-06T19:00:00Z" },
      { "id": "4-8", "username": "治愈系", "rating": 5, "content": "小王子离开星球后的每一段旅程都令人心碎又温暖，治愈系的天花板之作。", "timestamp": "2026-06-07T12:40:00Z" },
      { "id": "4-9", "username": "冷眼旁观", "rating": 2, "content": "过誉了，故事过于简单，哲理性的句子固然优美但缺乏深度，更适合儿童阅读。", "timestamp": "2026-06-08T09:00:00Z" },
      { "id": "4-10", "username": "狐狸粉", "rating": 4, "content": "狐狸说的那段话每次读都想哭，被驯养意味着建立联系，这是关于爱最美的诠释。", "timestamp": "2026-06-09T15:20:00Z" },
      { "id": "4-11", "username": "诗意人生", "rating": 5, "content": "这本书教给我们的远比任何说教都多，关于爱、责任和失去，都藏在这朵玫瑰里。", "timestamp": "2026-06-10T11:50:00Z" },
      { "id": "4-12", "username": "求深者", "rating": 3, "content": "虽然有些名句很打动人，但整体感觉偏单薄，作为哲学读物略显肤浅。", "timestamp": "2026-06-11T17:10:00Z" },
      { "id": "4-13", "username": "飞行家", "rating": 5, "content": "圣埃克苏佩里用最纯真的笔触写出了最深刻的孤独与爱，无与伦比的作品。", "timestamp": "2026-06-12T08:30:00Z" },
      { "id": "4-14", "username": "星球旅客", "rating": 4, "content": "每个星球上的人都像极了现实中的我们，虚荣的人、酒鬼、商人，讽刺得入木三分。", "timestamp": "2026-06-13T13:00:00Z" },
      { "id": "4-15", "username": "初心者", "rating": 5, "content": "这不是一本童书，这是一面镜子，让每个大人重新审视自己是否还记得初心。", "timestamp": "2026-06-14T16:40:00Z" },
      { "id": "4-16", "username": "解构派", "rating": 3, "content": "画面感很强，故事温馨感人，但个人觉得寓意被过度解读了，也许只是一个童话。", "timestamp": "2026-06-15T10:20:00Z" },
      { "id": "4-17", "username": "忧伤美", "rating": 4, "content": "小王子的忧伤如此动人，那种纯粹的、不带任何功利的爱让人向往又心疼。", "timestamp": "2026-06-16T14:50:00Z" },
      { "id": "4-18", "username": "寻回童真", "rating": 5, "content": "所有的大人都曾经是小孩，只是很少有人记得了。这本书帮我找回了那个孩子。", "timestamp": "2026-06-17T09:30:00Z" },
      { "id": "4-19", "username": "无感者", "rating": 2, "content": "故事太短了，读完没什么特别的感觉，不理解为什么被奉为经典，可能文化差异吧。", "timestamp": "2026-06-18T18:00:00Z" },
      { "id": "4-20", "username": "星空下", "rating": 5, "content": "玫瑰的骄傲与脆弱、狐狸的智慧与深情，每个角色都让人爱不释手，妙不可言。", "timestamp": "2026-06-20T07:40:00Z" }
    ]
  },
