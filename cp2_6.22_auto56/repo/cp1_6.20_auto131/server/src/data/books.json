    "reviews": [
      { "id": "3-1", "username": "星际旅人", "rating": 5, "content": "刘慈欣的想象力令人震撼，黑暗森林法则的提出堪称科幻史上的天才构思，叹为观止。", "timestamp": "2026-06-01T08:00:00Z" },
      { "id": "3-2", "username": "科幻迷老李", "rating": 5, "content": "中国科幻的里程碑之作，从三体问题到宇宙社会学，每一个设定都让人拍案叫绝。", "timestamp": "2026-06-01T13:20:00Z" },
      { "id": "3-3", "username": "文科生视角", "rating": 3, "content": "硬科幻部分太重了，大量物理知识让非理科读者很吃力，故事节奏也有些不均匀。", "timestamp": "2026-06-02T10:45:00Z" },
      { "id": "3-4", "username": "银河漫步", "rating": 4, "content": "第一部节奏稍慢但铺垫扎实，后面越来越精彩，三体世界的设定令人惊艳。", "timestamp": "2026-06-03T16:30:00Z" },
      { "id": "3-5", "username": "脑洞达人", "rating": 5, "content": "三体游戏的设计太巧妙了，用游戏来展现三体文明的历史，这是天才的叙事方式。", "timestamp": "2026-06-04T09:15:00Z" },
      { "id": "3-6", "username": "文学派", "rating": 2, "content": "对人物塑造太薄弱了，叶文洁之外的角色都像工具人，科幻迷可能喜欢但文学性不足。", "timestamp": "2026-06-05T14:00:00Z" },
      { "id": "3-7", "username": "仰望星空", "rating": 5, "content": "宇宙的黑暗森林让人不寒而栗，读完再看星空的感觉完全不同了，这就是好科幻。", "timestamp": "2026-06-06T20:30:00Z" },
      { "id": "3-8", "username": "耐心有限", "rating": 3, "content": "前半部分很精彩，但中间有些拖沓，物理学知识过多影响了故事的可读性。", "timestamp": "2026-06-07T11:10:00Z" },
      { "id": "3-9", "username": "硬核科幻", "rating": 5, "content": "大刘用硬核的物理学构建了一个令人窒息的宇宙图景，这才是真正的硬科幻巅峰。", "timestamp": "2026-06-08T17:45:00Z" },
      { "id": "3-10", "username": "推荐达人", "rating": 4, "content": "三体文明的社会形态令人着迷，与人类文明的对比引人深思，推荐给所有科幻爱好者。", "timestamp": "2026-06-09T08:20:00Z" },
      { "id": "3-11", "username": "普通读者", "rating": 3, "content": "科学设定虽然精彩但有些过于密集，对普通读者不太友好，需要很强的耐心。", "timestamp": "2026-06-10T12:30:00Z" },
      { "id": "3-12", "username": "宇宙尘", "rating": 5, "content": "这本书重新定义了中国科幻，三体问题与人类命运的交织堪称绝妙。", "timestamp": "2026-06-11T15:50:00Z" },
      { "id": "3-13", "username": "叙事分析", "rating": 5, "content": "红岸基地的往事和三体世界的秘密交替展开，叙事结构精妙，引人入胜。", "timestamp": "2026-06-12T10:00:00Z" },
      { "id": "3-14", "username": "逻辑怪", "rating": 2, "content": "人物动机有时不太合理，叶文洁的决定缺乏足够的铺垫，但创意确实出色。", "timestamp": "2026-06-13T14:40:00Z" },
      { "id": "3-15", "username": "大刘粉丝", "rating": 4, "content": "虽然文学性一般，但科幻创意的震撼力足以弥补，大刘是真正的想象力天才。", "timestamp": "2026-06-14T19:15:00Z" },
      { "id": "3-16", "username": "冷静评价", "rating": 3, "content": "作为科幻小说很不错，但被过度神话了，文学性和人物塑造还有很大提升空间。", "timestamp": "2026-06-15T07:30:00Z" },
      { "id": "3-17", "username": "文化自信", "rating": 5, "content": "从文革到宇宙末日，刘慈欣的视野之广阔令人叹服，这是属于中国人的科幻史诗。", "timestamp": "2026-06-16T11:00:00Z" },
      { "id": "3-18", "username": "概念控", "rating": 5, "content": "智子封锁、面壁计划，每一个概念都让人耳目一新，中国科幻的希望所在。", "timestamp": "2026-06-17T16:20:00Z" },
