      { "id": "6-13", "username": "女权视角", "rating": 2, "content": "过于刻薄了，对女性角色的描写带有明显的偏见，现代人读来不太舒服。", "timestamp": "2026-06-12T16:30:00Z" },
      { "id": "6-14", "username": "人物分析", "rating": 5, "content": "苏文纨、唐晓芙、孙柔嘉，每个女性角色都有深意，方鸿渐的选择就是他的命运。", "timestamp": "2026-06-13T08:40:00Z" },
      { "id": "6-15", "username": "无力感", "rating": 4, "content": "从法国到上海到三闾大学，方鸿渐每一步都是被推着走，这种无力感太真实了。", "timestamp": "2026-06-14T14:10:00Z" },
      { "id": "6-16", "username": "真实党", "rating": 3, "content": "比喻虽妙但有些过于矫情，刻意追求机智反而削弱了情感的真实性。", "timestamp": "2026-06-15T10:50:00Z" },
      { "id": "6-17", "username": "时代之镜", "rating": 5, "content": "围城写尽了知识分子的虚伪与挣扎，每个时代都有方鸿渐式的悲剧人物。", "timestamp": "2026-06-16T07:30:00Z" },
      { "id": "6-18", "username": "人情世故", "rating": 4, "content": "钱锺书对中国社会的人情世故观察入微，讽刺之下是对人性的深刻洞察。", "timestamp": "2026-06-17T15:20:00Z" },
      { "id": "6-19", "username": "不明觉厉", "rating": 2, "content": "不理解为什么评价这么高，可能是我水平不够，读起来只觉得矫情又无聊。", "timestamp": "2026-06-18T12:00:00Z" },
      { "id": "6-20", "username": "围城名句", "rating": 5, "content": "城外的人想冲进去城里的人想逃出来，这句话本身就已经道尽了人生的荒诞。", "timestamp": "2026-06-20T09:40:00Z" }
    ]
