{
  "name": "virtual-bookshelf",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"tsx watch server/server.ts\" \"vite\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "uuid": "^10.0.0",
    "recharts": "^2.12.7",
    "jspdf": "^2.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.9",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "tsx": "^4.16.0",
    "concurrently": "^8.2.2"
  }
}
