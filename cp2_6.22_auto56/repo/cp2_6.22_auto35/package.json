{
  "name": "trailplanner",
  "version": "1.0.0",
  "description": "户外徒步路线规划与分享平台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/backend/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "@types/leaflet": "^1.9.8",
    "express": "^4.18.3",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "axios": "^1.6.7",
    "uuid": "^9.0.1",
    "@types/uuid": "^9.0.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "recharts": "^2.12.3",
    "zustand": "^4.5.2",
    "lucide-react": "^0.363.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1"
  }
}
