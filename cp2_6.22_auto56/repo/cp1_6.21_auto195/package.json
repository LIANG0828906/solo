{
  "name": "restaurant-management",
  "version": "1.0.0",
  "description": "Restaurant daily specials menu, booking and notification system",
  "type": "commonjs",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "ts-node --project tsconfig.server.json server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "express": "4.18.2",
    "cors": "2.8.5",
    "uuid": "9.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "axios": "1.6.5",
    "recharts": "2.10.3",
    "react-icons": "4.12.0"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "@vitejs/plugin-react": "4.2.1",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/uuid": "9.0.7",
    "@types/node": "20.10.6",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.2.18",
    "concurrently": "8.2.2",
    "ts-node": "10.9.2"
  }
}
