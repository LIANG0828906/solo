{
  "name": "sketch-to-vector",
  "version": "1.0.0",
  "description": "手绘草稿智能转绘为矢量线稿应用",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "multer": "^2.0.0",
    "sharp": "^0.34.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "@vitejs/plugin-react": "^4.3.3",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.0"
  }
}
