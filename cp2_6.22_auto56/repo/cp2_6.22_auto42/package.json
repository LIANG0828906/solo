{
  "name": "typhoon-3d-visualizer",
  "version": "1.0.0",
  "description": "三维台风动态模拟与灾情可视化工具",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"FRONT,BACK\" -c \"cyan,magenta\" \"vite\" \"tsx src/server/server.ts\"",
    "dev:front": "vite",
    "dev:back": "tsx src/server/server.ts",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.160.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
}
