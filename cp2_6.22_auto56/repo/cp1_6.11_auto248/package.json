{
  "name": "ancient-academy-attendance",
  "version": "1.0.0",
  "description": "古代书院学规考勤与课业管理系统",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "ts-node server/server.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/socket.io": "^3.0.2",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.4"
  }
}
