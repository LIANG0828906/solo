  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.16",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
