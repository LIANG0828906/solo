    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.9",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^1.8.27",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
