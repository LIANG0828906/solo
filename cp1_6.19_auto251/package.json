{
  "name": "schedule-sprite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/backend/server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "zustand": "^4.5.4",
    "framer-motion": "^11.3.2",
    "html2canvas": "^1.4.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "tsx": "^4.16.2",
    "concurrently": "^8.2.2"
  }
}
